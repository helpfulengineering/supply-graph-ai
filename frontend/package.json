    "@tanstack/react-query": "^5.67.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cytoscape": "^3.30.4",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.2",
    "fflate": "^0.8.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.23.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.0.0",
    "react-cytoscapejs": "^2.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.1.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.4.1",
    "remark-gfm": "^4.0.1",
