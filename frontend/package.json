    "openapi-typescript": "^7.13.0",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.1.3",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.2.4",
    "vitest": "^4.1.9"
  }
